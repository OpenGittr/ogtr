# ogtr backend — sample configuration (ARCHITECTURE.md §7).
# Copy to configs/.local.env for local development (gitignored). Gofr loads
# configs/.env first, then overrides with configs/.local.env automatically.
# No real secrets in git, ever.

APP_NAME=ogtr
LOG_LEVEL=INFO

# Ports (project block 5800-5899, see docs/LOCAL_DEVELOPMENT.md)
HTTP_PORT=5810
METRICS_PORT=5811

# MySQL (docker-compose publishes host port 5830)
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=5830
DB_USER=root
DB_PASSWORD=
DB_NAME=ogtr

# Short-link generation + already-short detection
SHORT_DOMAIN=localhost:5810
SHORT_SCHEME=http

# SPA origin, for CORS + OAuth redirect
APP_URL=http://localhost:5800

# CORS (Gofr built-in middleware). Keep in sync with APP_URL: without this,
# Gofr defaults Access-Control-Allow-Origin to "*". Comma-separate to allow
# several origins. Not needed when the SPA is served same-origin / dev-proxied.
ACCESS_CONTROL_ALLOW_ORIGIN=http://localhost:5800

# Enabled sign-in methods, comma-separated. Valid values: google, dev.
# Unset defaults to "google". Unknown values refuse to start.
# Set to "google,dev" or "dev" for local evaluation: the dev provider is a
# zero-setup name+email sign-in that trusts any submitted identity — it needs
# no Google OAuth client, and it must NEVER be enabled in production.
AUTH_PROVIDERS=google

# Google sign-in audience (OIDC). Served to the SPA via
# GET /api/v1/auth/providers (a client ID is public, not a secret).
GOOGLE_CLIENT_ID=

# Google signing-key set. Leave empty for Google's real JWKS; only local
# tests/E2E point this elsewhere. There is no auth-bypass mode.
GOOGLE_JWKS_URL=

# ogtr session tokens (generate a long random string)
JWT_SIGNING_KEY=

# Session token lifetimes (Go durations). Defaults: 15m access, 720h refresh.
ACCESS_TOKEN_TTL=
REFRESH_TOKEN_TTL=

# utm_source value stamped on direct-traffic clicks (UTM auto-tag).
# Unset defaults to SHORT_DOMAIN — set only to override with a brand name.
UTM_SELF_SOURCE=

# Bare-domain bounce: where GET / (no short code) 302s to, e.g. the
# marketing site. Unset: the bare domain answers 404.
WEBSITE_URL=

# --- Abuse protection (docs/DEPLOYMENT.md §6) ---

# Shown to users on flagged-destination errors, the disabled-link (410) page
# and the /{code}+ preview page ("If you believe this is a mistake, contact
# ..."). Empty: no contact line. Also the address SECURITY.md points at.
ABUSE_CONTACT=

# Comma-separated plaintext blocklist feeds (one host or URL per line, "#"
# comments). Loaded in the background at startup, refreshed on
# BLOCKLIST_REFRESH_INTERVAL; a failed fetch keeps the last-good data.
# Recommended public feeds:
#   https://urlhaus.abuse.ch/downloads/text_online/           (malware URLs)
#   https://openphish.com/feed.txt                            (phishing URLs)
#   https://zerodot1.gitlab.io/CoinBlockerLists/hosts_browser (cryptojacking hosts)
# Empty: no feed layer (syntactic guards still apply).
BLOCKLIST_FEED_URLS=

# Feed refresh interval (Go duration). Default 6h.
BLOCKLIST_REFRESH_INTERVAL=

# Google Web Risk lookup API key. Set: every new/edited destination is also
# checked against Web Risk (2s timeout, FAILS OPEN when unreachable — the
# local layers are the floor). Empty: layer disabled.
WEBRISK_API_KEY=

# Extra reserved words (comma-separated) that can never become short codes,
# on top of the built-in curated list (docs/DEPLOYMENT.md §6). Applies on
# the shared domain AND on org custom domains.
RESERVED_ALIASES=

# Extra URL-shortener hosts to refuse as destinations (chaining), on top of
# the built-in list (bit.ly, tinyurl.com, t.co, ...).
SHORTENER_DOMAINS=

# Re-scan interval for destinations of recently clicked links (Go duration;
# default 24h; >=24h runs daily). Flagged links flip to DISABLED_ABUSE and
# answer 410 instead of redirecting.
RESCAN_INTERVAL=

# Link creations + destination edits allowed per user (or API key) per
# minute. Default 30. Per-instance, in-memory (see docs/DEPLOYMENT.md).
LINK_CREATE_RATE=

# Optional GeoIP (ARCHITECTURE.md §6); empty = disabled. Both files are
# MaxMind-licensed and must NEVER be committed — put them in the gitignored
# backend/data/ for local dev (deployments mount them instead).
# - GEOIP_DB_PATH: GeoLite2-City .mmdb, opened once at startup. Unset:
#   clicks record no city and location rule conditions never match.
# - GEOIP_CITIES_CSV: GeoLite2-City-Locations-en.csv, loaded into memory once
#   for GET /api/v1/cities autocomplete. Unset: that endpoint returns 501.
# Example: GEOIP_DB_PATH=data/GeoLite2-City.mmdb
#          GEOIP_CITIES_CSV=data/GeoLite2-City-Locations-en.csv
GEOIP_DB_PATH=
GEOIP_CITIES_CSV=
