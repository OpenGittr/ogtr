# ogtr instance-admin service — sample configuration (ARCHITECTURE.md
# "Instance admin service"). Copy to configs/.local.env for local
# development (gitignored). Gofr loads configs/.env first, then overrides
# with configs/.local.env automatically. No real secrets in git, ever.
#
# This service is cluster-internal only (deployed as `ogtr-internal`) and
# must never be reachable from the internet. It serves ONLY the
# /api/internal/* operator API; the public product is backend/server.

APP_NAME=ogtr-internal
LOG_LEVEL=INFO

# Ports (project block 5800-5899; the +20 secondary-backend slot — see
# docs/LOCAL_DEVELOPMENT.md). In k8s the pod env sets 8000/2121 instead.
HTTP_PORT=5820
METRICS_PORT=5821

# MySQL — the SAME database as backend/server (docker-compose publishes host
# port 5830 locally). Schema is owned by the public server, which runs the
# migrations at boot; this service never migrates.
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=5830
DB_USER=root
DB_PASSWORD=
DB_NAME=ogtr

# The admin token (gate.go). When set, every /api/internal/* request whose
# X-Admin-Token header equals this value is served — an operations console
# or plain curl can drive the API. Unset (the default): every endpoint
# answers 404, as if the service did not exist. Generate a long random
# value, e.g. `openssl rand -hex 32`. Any holder of this token has full
# cross-organization admin control — treat it like a root password. It is
# defense in depth on top of the primary control: network isolation.
ADMIN_API_TOKEN=
