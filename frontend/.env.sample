# Copy to .env.local (gitignored) for local development.

# Google OAuth client ID for the Google Identity Services sign-in button.
# Use your own Google OAuth Web client ID (docs/LOCAL_DEVELOPMENT.md, "Google
# OAuth" section). Leave empty to see a clear
# "not configured" notice instead of a broken button.
VITE_GOOGLE_CLIENT_ID=

# API base URL. Leave empty for same-origin requests: the Vite dev server
# proxies /api/* to http://localhost:5810 (see vite.config.ts), and production
# should either serve app + API behind one host or set this at build time.
VITE_API_URL=
